{
    "name": "musicfree-desktop",
    "productName": "MusicFree",
    "version": "1.0.0-beta.4",
    "description": "一个插件化的音乐播放器",
    "main": ".webpack/main",
    "private": true,
    "scripts": {
        "start": "electron-forge start",
        "dev": "chcp 65001 && electron-forge start --inspect-electron",
        "package": "cross-env NODE_ENV=production electron-forge package",
        "make": "cross-env NODE_ENV=production electron-forge make",
        "publish": "electron-forge publish",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "lint": "eslint ./src",
        "lint:fix": "eslint ./src --fix",
        "lint-staged": "lint-staged",
        "prepare": "husky"
    },
    "keywords": [
        "music",
        "player",
        "MusicFree",
        "electron",
        "plugin"
    ],
    "homepage": "https://musicfree.catcat.work",
    "repository": {
        "type": "git",
        "url": "https://github.com/maotoumao/MusicFreeDesktop.git"
    },
    "bugs": {
        "url": "https://github.com/maotoumao/MusicFreeDesktop/issues"
    },
    "author": {
        "name": "maotoumao",
        "email": "lhx_xjtu@163.com"
    },
    "license": "AGPL-3.0-only",
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "macos-alias",
            "fs-xattr"
        ]
    },
    "devDependencies": {
        "@electron-forge/cli": "^7.11.2",
        "@electron-forge/maker-deb": "^7.11.2",
        "@electron-forge/maker-dmg": "^7.11.2",
        "@electron-forge/maker-rpm": "^7.11.2",
        "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
        "@electron-forge/plugin-fuses": "^7.11.2",
        "@electron-forge/plugin-webpack": "^7.11.2",
        "@electron/fuses": "^1.8.0",
        "@eslint/js": "^9.39.2",
        "@svgr/webpack": "^8.1.0",
        "@timfish/forge-externals-plugin": "^0.2.2",
        "@types/better-sqlite3": "^7.6.13",
        "@types/he": "^1.2.3",
        "@types/qs": "^6.15.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/yauzl": "^3.4.0",
        "@vercel/webpack-asset-relocator-loader": "1.10.0",
        "cross-env": "^10.1.0",
        "css-loader": "^6.11.0",
        "electron": "40.4.0",
        "eslint": "^9.39.2",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import": "^2.32.0",
        "fork-ts-checker-webpack-plugin": "^7.3.0",
        "globals": "^17.6.0",
        "husky": "9.1.7",
        "lint-staged": "16.2.7",
        "node-loader": "^2.1.0",
        "prettier": "^3.8.4",
        "sass": "^1.101.0",
        "sass-loader": "^16.0.7",
        "style-loader": "^3.3.4",
        "ts-loader": "^9.6.1",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.61.1"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@emotion/is-prop-valid": "^1.4.0",
        "axios": "^1.18.0",
        "better-sqlite3": "^12.11.1",
        "big-integer": "^1.6.52",
        "blurhash": "^2.0.5",
        "cheerio": "^1.2.0",
        "compare-versions": "^6.1.1",
        "crypto-js": "^4.2.0",
        "dayjs": "^1.11.21",
        "dompurify": "^3.4.11",
        "eventemitter3": "^5.0.4",
        "framer-motion": "^12.40.0",
        "he": "^1.2.0",
        "hls.js": "^1.6.16",
        "http-proxy-agent": "^9.1.0",
        "https-proxy-agent": "^9.1.0",
        "i18next": "^26.3.1",
        "iconv-lite": "^0.7.2",
        "jotai": "^2.20.1",
        "jschardet": "^3.1.4",
        "lucide-react": "^1.21.0",
        "node-id3": "^0.2.9",
        "marked": "^18.0.5",
        "music-metadata": "^11.13.0",
        "nanoid": "^5.1.14",
        "p-queue": "^9.3.0",
        "qs": "^6.15.2",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-i18next": "^17.0.8",
        "react-router": "^8.0.1",
        "react-virtuoso": "^4.18.7",
        "sharp": "^0.34.5",
        "tinykeys": "^4.0.0",
        "webdav": "^5.10.0",
        "yauzl": "^3.4.0"
    },
    "lint-staged": {
        "src/**/*.{js,jsx,ts,tsx,mjs,cjs}": [
            "prettier --write",
            "eslint --fix",
            "git add ."
        ],
        "*.{json,css,scss,html,yml,yaml}": [
            "prettier --write"
        ]
    }
}
